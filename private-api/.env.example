# =============================================================================
# Шаблон env-переменных для ПРИВАТНОГО API.
# В Yandex Cloud Functions значения подаются через Yandex Lockbox
# (смонтированный как env), локально — через .env (он в .gitignore).
#
# ★ Этот файл — публичный шаблон без секретов. Реальные значения никогда
#   не коммитим.
# =============================================================================

# --- Yandex Managed PostgreSQL ---------------------------------------------

# FQDN мастера. Console → MDB → кластер → Hosts.
YANDEX_PG_HOST=

# 6432 (pgbouncer) — обязательно для serverless. 5432 не использовать.
YANDEX_PG_PORT=6432

# Пользователь приватного API. По схеме private_data — RW для своих
# таблиц (users, auth_sessions, email_verify_tokens, magic_link_tokens,
# subscriptions, tickets, events_log и т.д.), и SELECT по public_data
# для раскрытия промокодов. Не использовать админский аккаунт.
YANDEX_PG_USER=private_api_writer
YANDEX_PG_PASSWORD=

# Имя БД (общая с public-api).
YANDEX_PG_DATABASE=gdekod

# CA-сертификат YC, PEM-содержимое одной строкой (с \n внутри).
YANDEX_PG_CA_CERT=

# --- JWT (этап 6.3) --------------------------------------------------------

# Секрет HS256 для подписи JWT. В Lockbox. Длина ≥ 32 байт.
# Локально для тестов можно сгенерировать: openssl rand -base64 48
JWT_SECRET=

# Срок жизни JWT в секундах. По ТЗ §3.6: 90 дней.
JWT_TTL_SECONDS=7776000

# --- SMS-провайдер (мок до получения ключей SMS.ru) ------------------------

# При пустом SMS_RU_API_ID работает мок: код пишется в console (для тестов),
# реальная отправка не делается. Подключение SMS.ru — отдельная задача
# после согласования договора.
SMS_RU_API_ID=

# --- Email-провайдер (мок до верификации Yandex Postbox) -------------------

# При пустом YANDEX_POSTBOX_SMTP_HOST работает мок: тело письма пишется
# в console. Реальная отправка — после верификации домена gde-code.ru
# (SPF/DKIM/DMARC) и подтверждения noreply@gde-code.ru в Yandex Postbox.
YANDEX_POSTBOX_SMTP_HOST=
YANDEX_POSTBOX_SMTP_PORT=587
YANDEX_POSTBOX_SMTP_USER=
YANDEX_POSTBOX_SMTP_PASSWORD=
YANDEX_POSTBOX_FROM=ГдеКод <noreply@gde-code.ru>

# --- Парсер-эндпоинты (этап 6.8) -------------------------------------------

# Общий секрет между парсером (Azure) и приватным API. Передаётся
# парсером в заголовке X-Parser-Secret. Минимум 32 байта random.
# Сравнение через timingSafeEqual в lib/parser-auth.js.
PARSER_SECRET=

# --- Health-check ----------------------------------------------------------

# Bearer-токен для /health. Используется внешним мониторингом.
# Без env-токена endpoint вернёт 500 — намеренно (чтобы health не стал
# случайно публичным).
PRIVATE_API_HEALTH_TOKEN=

# --- Параметры авторизации (значения по ТЗ §3.6, §3.7) ---------------------

# TTL OTP-кода (SMS), секунды. §3.6 / §24.4: 5 минут.
OTP_TTL_SECONDS=300

# Секрет для HMAC-SHA256 хеширования OTP-кодов перед записью в БД.
# В таблице otp_codes хранится только code_hash, не plain-код. По ТЗ:
# 6-значный OTP + TTL 5 мин + attempts_count ≤ 5 → атака brute-force
# невозможна онлайн; HMAC защищает от offline-перебора при dump БД.
# Минимум 32 байта, в проде — Yandex Lockbox.
OTP_HMAC_SECRET=

# TTL magic-link токена, секунды. §3.7.9: 30 минут.
MAGIC_LINK_TTL_SECONDS=1800

# TTL email-verify токена, секунды. §3.7.5: 24 часа.
EMAIL_VERIFY_TTL_SECONDS=86400
