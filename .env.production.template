# =============================================================================
# .env.production.template — шаблон переменных окружения для PRODUCTION.
#
# ★ ЭТОТ ФАЙЛ ПУБЛИЧЕН — без реальных значений. Коммитить ок.
# ★ Реальные значения хранятся ТОЛЬКО в Yandex Lockbox.
#   В Cloud Functions они монтируются как env-переменные автоматически.
#   Локально — .env (в .gitignore), никогда не в репо.
#
# Как сгенерировать криптостойкие секреты:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
#   openssl rand -base64 32
#
# Две Cloud Function-группы:
#   - public-api  → нужны только YANDEX_PG_* + PUBLIC_API_HEALTH_TOKEN + GIT_SHA
#   - private-api → все остальные
# =============================================================================


# =============================================================================
# YANDEX MANAGED POSTGRESQL
# Общая для public-api и private-api (разные пользователи).
# =============================================================================

# FQDN мастера. Console → Managed PostgreSQL → кластер → Хосты.
# Пример: rc1b-xxxxxxxx.mdb.yandexcloud.net
YANDEX_PG_HOST=

# ВАЖНО: 6432 (pgbouncer), не 5432. Serverless-функции не держат
# persistent connections — pgbouncer мультиплексирует тысячи логических
# соединений в десятки физических.
YANDEX_PG_PORT=6432

# Пользователи:
#   public-api  → public_api_reader  (SELECT по public_data, без private_data)
#   private-api → private_api_writer (RW по private_data + SELECT public_data)
# НЕ использовать владельца БД или admin-пользователя.
YANDEX_PG_USER=
YANDEX_PG_PASSWORD=

# Имя базы данных (общая для обоих API).
YANDEX_PG_DATABASE=gdekod

# CA-сертификат Yandex Cloud для SSL-соединения с PostgreSQL.
# PEM-содержимое одной строкой (переводы строк заменить на \n).
# Скачать: https://storage.yandexcloud.net/cloud-certs/CA.pem
# Команда для форматирования: awk 'NF {ORS="\\n"} 1' CA.pem
YANDEX_PG_CA_CERT=


# =============================================================================
# JWT И КРИПТОГРАФИЧЕСКИЕ СЕКРЕТЫ (только private-api)
# =============================================================================

# Секрет HS256 для подписи и верификации JWT.
# КРИТИЧНО: смена этого секрета инвалидирует ВСЕ активные сессии.
# Минимум 32 байта random base64.
# Генерация: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
JWT_SECRET=

# Срок жизни JWT, секунды. По ТЗ §3.6: 90 дней = 7776000 с.
# Изменение НЕ отзывает старые токены (нет blacklist) — только новые будут короче.
JWT_TTL_SECONDS=7776000

# Секрет HMAC-SHA256 для хеширования OTP-кодов перед записью в БД.
# В otp_codes и account_deletion_otp_codes хранится только code_hash.
# Защищает от offline-перебора при компрометации дампа БД.
# Минимум 32 байта random base64.
OTP_HMAC_SECRET=

# TTL OTP-кода для входа (SMS/flash_call), секунды. §3.6: 5 минут.
OTP_TTL_SECONDS=300

# TTL magic-link токена, секунды. §3.7.9: 30 минут.
MAGIC_LINK_TTL_SECONDS=1800

# TTL email-verify токена, секунды. §3.7.5: 24 часа.
EMAIL_VERIFY_TTL_SECONDS=86400


# =============================================================================
# SMS-ПРОВАЙДЕР: SMS.RU (только private-api)
# =============================================================================

# API-ключ личного кабинета SMS.ru.
# При пустом значении — fallback на mock (логирование в console).
# В production ДОЛЖЕН быть задан через Lockbox.
# Получить: https://sms.ru → API → Ключ API
SMS_RU_API_ID=


# =============================================================================
# EMAIL-ПРОВАЙДЕР: YANDEX POSTBOX (только private-api)
# =============================================================================

# SMTP-relay хост Yandex Postbox. При пустом — fallback на mock.
# Значение: smtp.postbox.yandexcloud.net
YANDEX_POSTBOX_SMTP_HOST=smtp.postbox.yandexcloud.net

# SMTP порт (STARTTLS).
YANDEX_POSTBOX_SMTP_PORT=587

# SMTP логин (адрес отправителя, верифицированный в Postbox).
YANDEX_POSTBOX_SMTP_USER=noreply@gde-code.ru

# SMTP пароль (из Yandex Postbox, не от Яндекс-аккаунта).
YANDEX_POSTBOX_SMTP_PASSWORD=

# Отображаемое имя и адрес отправителя.
YANDEX_POSTBOX_FROM=ГдеКод <noreply@gde-code.ru>


# =============================================================================
# ПАРСЕР-ЭНДПОИНТЫ (только private-api)
# =============================================================================

# Shared secret между парсером (Azure) и private-api.
# Передаётся в заголовке X-Parser-Secret. Сравнение через timingSafeEqual.
# Минимум 32 байта random base64. Должен совпадать с env парсера.
PARSER_SECRET=


# =============================================================================
# HEALTH-CHECK ТОКЕНЫ
# =============================================================================

# Bearer-токены для /health endpoint'ов.
# Используются UptimeRobot / Yandex Monitoring / CI smoke-test.
# Без токена в env → endpoint вернёт 500 (намеренная защита от случайного
# публичного доступа через "забытый" env).
PRIVATE_API_HEALTH_TOKEN=
PUBLIC_API_HEALTH_TOKEN=


# =============================================================================
# ОКРУЖЕНИЕ
# =============================================================================

# Режим работы. КРИТИЧНО: всегда 'production' на production.
# Влияет на: assertNoMockInProduction(), getAvailableProviders(),
# уровень логирования ошибок.
NODE_ENV=production

# Git SHA деплоя — отображается в GET /health как version.
# Устанавливается автоматически при деплое через yc CLI:
#   --environment GIT_SHA=$(git rev-parse HEAD)
# Без переменной /health вернёт version='dev'.
GIT_SHA=


# =============================================================================
# БИЛЛИНГ — ЗАЩИТА ОТ MOCK В PRODUCTION
# =============================================================================

# КРИТИЧНО: ВСЕГДА 'false' в production.
# 'true' допустимо только на staging (operator_mock не подключён к реальным
# операторам). При NODE_ENV=production И MOCK_OPERATOR_BILLING=true —
# assertNoMockInProduction() выбросит исключение и функция не запустится.
MOCK_OPERATOR_BILLING=false


# =============================================================================
# YANDEX CLOUD (для деплоя через yc CLI / GitHub Actions)
# =============================================================================

# ID folder'а в Yandex Cloud. Console → выбрать folder → скопировать ID.
YC_FOLDER_ID=

# OAuth-токен сервисного аккаунта с ролями:
#   - serverless.functions.admin (создание версий функций)
#   - lockbox.payloadViewer (чтение секретов)
#   - mdb.viewer (просмотр кластеров PostgreSQL — для проверки)
# В GitHub Actions хранить в Secrets.
YC_OAUTH_TOKEN=
