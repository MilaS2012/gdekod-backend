# =============================================================================
# Шаблон env-переменных для gdekod-backend.
# В Yandex Cloud Functions реальные значения подаются через Yandex Lockbox →
# смонтированы как env-переменные функции.
# Локально (для отладки) копировать в .env (он в .gitignore).
# =============================================================================

# --- PostgreSQL (Yandex Managed PostgreSQL) ---------------------------------

# FQDN мастера кластера. Console → MDB → кластер → Hosts.
YANDEX_PG_HOST=

# 6432 — pgbouncer (для приложений, обязательно для serverless).
# 5432 — прямое подключение, не использовать в Cloud Functions.
YANDEX_PG_PORT=6432

# Пользователь и пароль БД. Создаются при настройке кластера.
# В прод: пароль приходит из Lockbox, в .env его быть не должно.
YANDEX_PG_USER=
YANDEX_PG_PASSWORD=

# Имя БД.
YANDEX_PG_DATABASE=

# CA-сертификат YC в виде PEM-содержимого (одной переменной, с переносами \n).
# В Cloud Functions: Lockbox secret с PEM-телом → монтируется в env.
# Локально: скачать с https://storage.yandexcloud.net/cloud-certs/CA.pem
# и положить содержимое сюда.
YANDEX_PG_CA_CERT=

# --- Опциональные настройки -------------------------------------------------

# Уровень логирования. По умолчанию info.
LOG_LEVEL=info
