# ГдеКод — парсер · переменные окружения
# Скопировать в .env и заполнить

# Yandex API — куда отправляем результаты проверок
YANDEX_API_URL=https://api.gde-code.ru

# Секретный ключ для аутентификации Azure → Yandex
# Должен совпадать с PARSER_SECRET_KEY в Yandex Cloud Functions
PARSER_SECRET_KEY=replace_with_real_secret

# Какой tier запускать (1 / 2 / 3)
PARSER_TIER=1

# Размер батча — сколько промокодов брать за один запрос к API
BATCH_SIZE=10

# Параллельных браузеров одновременно
# 3 — безопасно для $30-40/мес на Container Instances
MAX_CONCURRENCY=3

# Не отправлять ПД в логи Azure (всегда true)
NODE_ENV=production
