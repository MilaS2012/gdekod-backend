# =============================================================================
# Шаблон env-переменных для публичного API.
# В Yandex Cloud Functions значения подаются через Yandex Lockbox
# (смонтированный как env), локально — через .env (он в .gitignore).
# =============================================================================

# --- Yandex Managed PostgreSQL ---------------------------------------------

# FQDN мастера. Console → MDB → кластер → Hosts.
YANDEX_PG_HOST=

# 6432 (pgbouncer) — обязательно для serverless. 5432 не использовать.
YANDEX_PG_PORT=6432

# Read-only пользователь публичного API. Имеет SELECT по схеме public_data
# и больше ничего. Не использовать админский аккаунт.
YANDEX_PG_USER=public_api_reader
YANDEX_PG_PASSWORD=

# Имя БД.
YANDEX_PG_DATABASE=gdekod

# CA-сертификат YC, PEM-содержимое одной строкой (с \n внутри).
# В Lockbox удобно класть как secret.
YANDEX_PG_CA_CERT=

# --- Внутренний health-check -----------------------------------------------

# Bearer-токен для /health. Используется внешним мониторингом (UptimeRobot,
# Yandex Monitoring). Если переменная не задана — endpoint вернёт 500
# (мы НЕ хотим, чтобы health случайно стал публичным без защиты).
PUBLIC_API_HEALTH_TOKEN=
